#!/usr/bin/env bash
s_out=""
s_in=""
while [[ $# -gt 0 ]]; do
    case $1 in
        -o) s_out="$2"; shift 2 ;;
        -f|-t) shift 2 ;;
        -s) shift ;;
        *)  [[ -z "$s_in" ]] && s_in="$1"; shift ;;
    esac
done

[[ -z "$s_out" ]] && exit 1

s_body="<h1>Stub Output</h1>
<p>Generated by pandoc stub.</p>"
if [[ -n "$s_in" && -f "$s_in" ]]; then
    s_body="$(<"$s_in")"
fi

cat > "$s_out" <<ENDHTML
<!DOCTYPE html>
<html>
<head>
<title>stub</title>
<style>
</style>
</head>
<body>
${s_body}
</body>
</html>
ENDHTML
